#!/usr/bin/env bash
# Source this script to load infra env vars into your shell:
#   source load-infra-env

if [ -z "${DATA_DIR:-}" ]; then
  echo "ERROR: DATA_DIR is not set. Are you in the dev shell? (nix develop)" >&2
  return 1 2>/dev/null || exit 1
fi

if [ ! -f "$RABBITMQ_AMQP_PORT_FILE" ]; then
  echo "ERROR: RabbitMQ port file not found. Is infra running? (start-infra)" >&2
  return 1 2>/dev/null || exit 1
fi

export RABBITMQ_AMQP_PORT=$(cat "$RABBITMQ_AMQP_PORT_FILE")
export RABBITMQ_MGMT_PORT=$(cat "$RABBITMQ_MGMT_PORT_FILE")
export RABBITMQ_URL="amqp://guest:guest@127.0.0.1:$RABBITMQ_AMQP_PORT"

echo "RABBITMQ_URL=$RABBITMQ_URL"
echo "RABBITMQ_AMQP_PORT=$RABBITMQ_AMQP_PORT"
echo "RABBITMQ_MGMT_PORT=$RABBITMQ_MGMT_PORT"

if [ -f "$MINIO_API_PORT_FILE" ]; then
  export MINIO_API_PORT=$(cat "$MINIO_API_PORT_FILE")
  export S3_ENDPOINT="http://127.0.0.1:$MINIO_API_PORT"
  export S3_ACCESS_KEY="minioadmin"
  export S3_SECRET_KEY="minioadmin"
  export S3_HOT_BUCKET="synapse-hot"
  export S3_COLD_BUCKET="synapse-cold"
  echo "S3_ENDPOINT=$S3_ENDPOINT"
  echo "S3_HOT_BUCKET=$S3_HOT_BUCKET"
  echo "S3_COLD_BUCKET=$S3_COLD_BUCKET"
fi

export METADATA_FILE="$DATA_DIR/metadata.json"
export EVENT_LOG_FILE="$DATA_DIR/events.log"
echo "METADATA_FILE=$METADATA_FILE"
echo "EVENT_LOG_FILE=$EVENT_LOG_FILE"
